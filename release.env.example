# Copy to release.env for a signed local release. Never commit release.env.
export IMERGE_KEYSTORE_PATH="$HOME/.android/imerge-release.jks"
export IMERGE_KEYSTORE_PASSWORD="replace-me"
export IMERGE_KEY_ALIAS="imerge"
export IMERGE_KEY_PASSWORD="replace-me"
export IMERGE_VERSION_CODE="100001"
export IMERGE_VERSION_NAME="1.0.1"
